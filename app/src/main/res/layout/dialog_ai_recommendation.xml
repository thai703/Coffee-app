<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="10dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- Header Image with Overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <ImageView
                android:id="@+id/iv_ai_product"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_coffee" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_black_transparent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:background="@drawable/bg_badge_ai"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sparkle"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    app:fontFamily="@font/montserrat_bold"
                    android:text="AI gợi ý"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_ai_product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:fontFamily="@font/montserrat_bold"
                android:text="Cà phê Trứng"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textAlignment="center" />
            
             <TextView
                android:id="@+id/tv_ai_product_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:fontFamily="@font/montserrat_regular"
                android:text="45.000 VND"
                android:textColor="@color/premium_accent"
                android:textSize="18sp"
                android:textAlignment="center"
                android:layout_marginTop="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_quote_bubble"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="top"
                    android:src="@drawable/ic_quote"
                    app:tint="#757575" />

                <TextView
                    android:id="@+id/tv_ai_reason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    app:fontFamily="@font/montserrat_regular"
                    android:text="Hôm nay trời hơi se lạnh..."
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:textStyle="italic" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ai_add_to_cart"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/premium_accent"
                app:fontFamily="@font/montserrat_bold"
                android:text="Thử ngay"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_cart"
                app:iconGravity="textStart"
                app:iconTint="#FFFFFF" />

            <TextView
                android:id="@+id/tv_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:padding="8dp"
                app:fontFamily="@font/montserrat_regular"
                android:text="Để sau nhé"
                android:textColor="#9E9E9E"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
