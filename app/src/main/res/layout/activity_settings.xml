<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/premium_bg"
    tools:context=".UI.settings.SettingsActivity">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="@string/settings_title"
            app:titleTextColor="@color/brown_900" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Account Settings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/account_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="12dp"
                android:textColor="@color/brown_900"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_edit_profile"
                        style="@style/PremiumProfileItem"
                        android:text="@string/edit_profile"
                        app:drawableStartCompat="@drawable/ic_person" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="64dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/gray_200" />

                    <TextView
                        android:id="@+id/tv_change_password"
                        style="@style/PremiumProfileItem"
                        android:text="@string/change_password"
                        app:drawableStartCompat="@drawable/ic_lock" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- General Settings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/utilities_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="12dp"
                android:textColor="@color/brown_900"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_info"
                            app:tint="@color/premium_accent" />
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="24dp"
                            android:text="@string/notifications"
                            android:textColor="@color/brown_900"
                            android:textSize="15sp" />
                        
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_notification"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="@color/premium_accent"
                            app:trackTint="@color/premium_accent_light"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="64dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/gray_200" />
                    
                    <TextView
                        android:id="@+id/tv_language"
                        style="@style/PremiumProfileItem"
                        android:text="@string/system_language"
                        app:drawableStartCompat="@drawable/ic_language" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Support -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/support_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="12dp"
                android:textColor="@color/brown_900"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_help_center"
                        style="@style/PremiumProfileItem"
                        android:text="@string/help_center"
                        app:drawableStartCompat="@android:drawable/ic_menu_help" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="64dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/gray_200" />

                    <TextView
                        android:id="@+id/tv_privacy_policy"
                        style="@style/PremiumProfileItem"
                        android:text="@string/privacy_policy"
                        app:drawableStartCompat="@android:drawable/ic_menu_info_details" />
                        
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="64dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/gray_200" />

                    <TextView
                        android:id="@+id/tv_about_us"
                        style="@style/PremiumProfileItem"
                        android:text="@string/about_aura"
                        app:drawableStartCompat="@drawable/ic_info" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Logout Button (Unified design) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="32dp"
                android:text="@string/logout"
                android:textColor="@color/danger"
                android:textSize="16sp"
                android:textStyle="bold"
                app:strokeColor="@color/danger"
                app:strokeWidth="1.5dp"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_logout"
                app:iconTint="@color/danger"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>